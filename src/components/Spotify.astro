---
const playlistUrl = "https://open.spotify.com/embed/playlist/37i9dQZF1DWZeKCadgRdKQ"; 
---

<style>
  .spotify-embed {
    width: 100%;
    width: 700px;
    height: 400px;
    border-radius: 10px;
    border: 1px solid #4e937a;
    box-shadow: 0 0 15px #4e937a88;
    background-color: #1e1e1e;
    user-select: none;
  }
</style>

<iframe
  class="spotify-embed"
  src={playlistUrl}
  width="100%"
  height="400"
  frameborder="0"
  allowtransparency="true"
  allow="encrypted-media"
  title="Priyanka's Coding Playlist on Spotify"
  loading="lazy"
/>
